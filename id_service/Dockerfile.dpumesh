FROM gcc:13-bookworm AS build
WORKDIR /build
COPY common/ common/
COPY id_service/main_dpumesh.c .
RUN gcc -O2 -Wall -Icommon -o server main_dpumesh.c common/*.c

FROM debian:bookworm-slim
WORKDIR /app
COPY --from=build /build/server .
COPY id_service/data/ data/
ENV APP=id-service
ENV DATA_FILE=data/ids.json
CMD ["./server"]
