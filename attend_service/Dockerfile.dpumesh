FROM gcc:13-bookworm AS build
WORKDIR /build
COPY common/ common/
COPY attend_service/main_dpumesh.c .
RUN gcc -O2 -Wall -Icommon -o server main_dpumesh.c common/*.c

FROM debian:bookworm-slim
WORKDIR /app
COPY --from=build /build/server .
COPY attend_service/data/ data/
ENV APP=attend-service
ENV DATA_FILE=data/attendance.json
CMD ["./server"]
